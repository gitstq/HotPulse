# HotPulse 环境变量配置

# OpenAI API配置（用于AI分析，可选）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# 服务配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
DATABASE_PATH=hotpulse.db

# 抓取配置
FETCH_INTERVAL=300
MAX_ITEMS_PER_SOURCE=50

# 通知配置（可选）
WEBHOOK_URL=
DINGTALK_WEBHOOK=
WECHAT_WEBHOOK=
